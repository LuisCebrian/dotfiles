# Add local bin directory to path
export PATH=$PATH:~/.local/bin
export EDITOR=nvim

# Set the directory we want to store zinit and plugins
ZINIT_HOME="${HOME}/.local/share/zinit/zinit.git"

# Download Zinit, if it's not there yet
if [ ! -d "$ZINIT_HOME" ]; then
    mkdir - p "$(dirname $ZINIT_HOME)"
    git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi

# Source/Load zinit
source "${ZINIT_HOME}/zinit.zsh"

# Add in zsh plugins
zinit light zsh-users/zsh-syntax-highlighting
zinit light zsh-users/zsh-completions
zinit light zsh-users/zsh-autosuggestions
zinit light Aloxaf/fzf-tab

# Load completions
autoload -U compinit && compinit

# Configure prompt
eval "$(oh-my-posh init zsh --config ~/GIT/dotfiles/zsh/tokyonight_storm.omp.json)"

# Keybindings
bindkey -v
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward
bindkey '^f' autosuggest-accept
# Fix backward key after entering insert mode after normal mode
bindkey '^?' backward-delete-char

# History
HISTSIZE=5000
HISTFILE=~/.zsh_history
SAVEHIST=$HISTSIZE
HISTDUP=erase
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_ignore_dups

# Yank to the system clipboard
function vi-yank-system {
    zle vi-yank
   echo "$CUTBUFFER" | pbcopy -i
}

zle -N vi-yank-system
bindkey -M vicmd 'y' vi-yank-system

# Allow with C-x to edit the current command in a vim buffer
autoload -Uz edit-command-line
zle -N edit-command-line edit-command-line
bindkey '^x' edit-command-line

# Completion styling
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'

# Aliases
alias ls='ls --color'

# Load fzf installed with the install script
# https://github.com/junegunn/fzf?tab=readme-ov-file#using-git
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# fzf — Tokyo Night theme + layout
export FZF_DEFAULT_OPTS="
  --layout=reverse
  --border=rounded
  --height=40%
  --margin=1,15%
  --info=inline-right
  --prompt='❯ '
  --pointer='▶'
  --marker='✓'
  --color=bg+:#292e42,bg:#1a1b26,spinner:#7dcfff,hl:#7aa2f7
  --color=fg:#c0caf5,header:#7aa2f7,info:#7aa2f7,pointer:#7dcfff
  --color=marker:#9ece6a,fg+:#c0caf5,prompt:#7dcfff,hl+:#7aa2f7
  --color=border:#27a1b9"

# Shell integrations
eval "$(fzf --zsh)"
eval "$(zoxide init zsh)"

# Fuzzy-find a repo under ~/GIT and cd into it (Ctrl+G)
function fzf-cd-git() {
    local dir
    dir=$(cd ~/GIT && fd --type d --max-depth 1 | fzf)
    if [[ -n "$dir" ]]; then
        builtin cd -- "${HOME}/GIT/${dir}"
        local f
        for f in $precmd_functions; do
            $f
        done
    fi
    zle reset-prompt
}
zle -N fzf-cd-git
bindkey '^g' fzf-cd-git
